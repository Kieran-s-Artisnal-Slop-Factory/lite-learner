---
// Emits every course as a content bundle (course + chapters + exercises,
// each stamped with a content_hash) baked into the page. Resolving the
// reference() arrays here means a broken slug fails the build.
import { getCollection, getEntries } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import CoursesApp from '../components/apps/CoursesApp.svelte';
import { chapterContent, courseContent, exerciseContent } from '../lib/content/bundle';

const courseEntries = await getCollection('courses');
const bundles = await Promise.all(
  courseEntries.map(async (course) => {
    const chapterEntries = await getEntries(course.data.chapters);
    const missingChapter = chapterEntries.findIndex((c) => !c);
    if (missingChapter !== -1) {
      throw new Error(
        `Course "${course.id}" references missing chapter "${course.data.chapters[missingChapter]!.id}"`
      );
    }
    const exerciseEntries = (
      await Promise.all(
        chapterEntries.map(async (chapter) => {
          const entries = await getEntries(chapter.data.exercises);
          const missing = entries.findIndex((e) => !e);
          if (missing !== -1) {
            throw new Error(
              `Chapter "${chapter.id}" references missing exercise "${chapter.data.exercises[missing]!.id}"`
            );
          }
          return entries;
        })
      )
    ).flat();
    return {
      course: courseContent(course),
      chapters: chapterEntries.map(chapterContent),
      exercises: exerciseEntries.map(exerciseContent),
    };
  })
);
---

<Layout title="Courses">
  <CoursesApp client:only="svelte" {bundles} />
</Layout>
